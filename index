        "Je suis presque sûr qu’on peut faire mieux que rester plantés là à parler comme des gens sages.",
      ].map((text, i) => ({ id: `b${i}`, text, tag: "beauf", level: "real" }))
    ];

    const ALL_FLIRT_OPTIONS = [...DISCREET_POOL, ...REAL_POOL];
    const INSULTING_REJECTIONS = [
      "Franchement, non. Là tu me fatigues plus qu’autre chose.",
      "T’as cru que ça allait marcher avec une vibe pareille ?",
      "On va gagner du temps : c’est non.",
      "J’ai déjà vu plus séduisant dans une rame à 8h du mat.",
      "Tu parles beaucoup pour quelqu’un qui n’a aucune chance.",
      "Là t’es pas charmant, t’es juste gênant.",
      "J’ai connu des tickets de caisse plus inspirants.",
      "Non mais regarde-toi deux secondes.",
      "Même mon pire date avait plus de tenue que ça.",
      "Tu vas me laisser finir mon verre tranquillement, merci.",
    ];
    const ALL_REJECTIONS = [...INSULTING_REJECTIONS, ...Array.from({ length: 290 }, (_, i) => `Non. Là, ça prend pas du tout. Rejet ${i + 1}.`)].slice(0, 300);

    function getReply(pnj, tone) {
      if (pnj.isFabrist) return randomItem([
        "FABRISTE valide tout, avec beaucoup trop d’enthousiasme.",
        "FABRISTE est déjà conquis. Beaucoup trop vite.",
        "FABRISTE approuve, et c’est presque inquiétant.",
      ]);
      return randomItem(({
        intro: ["Ok, je t’écoute.", "Bon. T’as réussi à lancer la conversation.", "Vas-y, voyons ce que t’as."],
        positive: ["Pas mal.", "Là, c’est mieux.", "Ok, continue comme ça."],
        negative: ["Non, là c’est mauvais.", "Tu viens de perdre du terrain.", "Ouais non, pas celle-là."],
        neutral: ["Je vois l’idée.", "Mouais. Continue.", "Je suis pas encore convaincue."],
        unlock: ["Ok. Là, tu peux tenter un truc.", "Bon, t’as remonté ton niveau.", "Vas-y, propose la suite."],
        final: ["Allez, je t’écoute.", "Vas-y, joue-la bien.", "Ne gâche pas tout maintenant."],
      })[tone] || ["..."]);
    }

    function npcEmotionFromTone(tone, isFabrist = false) {
      if (isFabrist) return tone === "unlock" || tone === "final" ? "desir" : "joie";
      if (tone === "positive") return "joie";
      if (tone === "unlock" || tone === "final" || tone === "intro") return "desir";
      if (tone === "negative") return "degout";
      return "tristesse";
    }
    function playerEmotionFromTone(tone) { return tone === "negative" ? "tristesse" : tone === "positive" ? "joie" : "desir"; }
    function pickRejectText(harsh = false) { return harsh ? randomItem(INSULTING_REJECTIONS) : randomItem(ALL_REJECTIONS); }

    function createCharacter(forceFabrist = false) {
      if (forceFabrist) {
        return {
          id: `fab-${Date.now()}`,
          name: "FABRISTE",
          isFabrist: true,
          hair: { color: "#b48a68" },
          eyes: { color: "#d0d4de" },
          face: { key: "carre" },
          body: { key: "massif" },
          skin: "#c98d67",
          allowedOpener: null,
          preferredConclusion: null,
          likedTags: [...ARCHETYPES.directe.likedTags],
          dislikedTags: [],
          greenFlagIds: new Set(ALL_FLIRT_OPTIONS.map((line) => line.id)),
          redFlagIds: new Set(),
          greenUltimate: null,
          redUltimate: null,
          signature: "FABRISTE",
        };
      }

      const h = Math.floor(Math.random() * HAIR_OPTIONS.length);
      const e = Math.floor(Math.random() * EYE_OPTIONS.length);
      const f = Math.floor(Math.random() * FACE_OPTIONS.length);
      const b = Math.floor(Math.random() * BODY_OPTIONS.length);
      const hair = HAIR_OPTIONS[h];
      const eyes = EYE_OPTIONS[e];
      const face = FACE_OPTIONS[f];
      const body = BODY_OPTIONS[b];
      const archetypeKey = computeArchetype(h, e, f, b);
      const archetype = ARCHETYPES[archetypeKey];
      const likedCandidates = ALL_FLIRT_OPTIONS.filter((line) => archetype.likedTags.includes(line.tag || ""));
      const dislikedCandidates = ALL_FLIRT_OPTIONS.filter((line) => archetype.dislikedTags.includes(line.tag || ""));
      const neutralCandidates = ALL_FLIRT_OPTIONS.filter((line) => !archetype.likedTags.includes(line.tag || "") && !archetype.dislikedTags.includes(line.tag || ""));
      const greenFlags = sampleUnique([...likedCandidates, ...neutralCandidates], 8);
      const redFlags = sampleUnique([...dislikedCandidates, ...neutralCandidates], 8);
      const greenUltimateCandidates = likedCandidates.filter((line) => line.level === "real");
      const greenUltimate = randomItem(greenUltimateCandidates.length ? greenUltimateCandidates : REAL_POOL);
      const redUltimate = randomItem(dislikedCandidates.length ? dislikedCandidates : ALL_FLIRT_OPTIONS);

      return {
        id: `pnj-${Date.now()}-${Math.floor(Math.random() * 99999)}`,
        name: randomItem(EASTERN_NAMES),
        isFabrist: false,
        hairstyle: randomItem(FEMALE_HAIRSTYLES),
        outfit: randomItem(FEMALE_OUTFITS),
        hair,
        eyes,
        face,
        body,
        skin: colorForSkin(h + e + f),
        allowedOpener: (h + e + f) % 3,
        preferredConclusion: (e + b + f) % 3,
        likedTags: archetype.likedTags,
        dislikedTags: archetype.dislikedTags,
        greenFlagIds: new Set(greenFlags.filter((line) => line.id !== redUltimate.id).map((line) => line.id)),
        redFlagIds: new Set(redFlags.filter((line) => line.id !== greenUltimate.id).map((line) => line.id)),
        greenUltimate,
        redUltimate,
        signature: `${hair.label} • ${eyes.label} • ${face.label} • ${body.label}`,
      };
    }

    const state = {
      score: 0,
      bestiary: [],
      history: [],
      drawer: null,
      overlay: false,
      current: null,
      stage: "opening",
      greens: 0,
      reds: 0,
      discreetTurns: 0,
      choices: [...INTRO_OPTIONS],
      log: [],
      status: "active",
      playerEmotion: "desir",
      npcEmotion: "tristesse",
    };

    const els = {
      scoreValue: document.getElementById('scoreValue'),
      npcName: document.getElementById('npcName'),
      playerPortrait: document.getElementById('playerPortrait'),
      npcPortrait: document.getElementById('npcPortrait'),
      playerEmotion: document.getElementById('playerEmotion'),
      npcEmotion: document.getElementById('npcEmotion'),
      phaseLabel: document.getElementById('phaseLabel'),
      restartBtn: document.getElementById('restartBtn'),
      log: document.getElementById('log'),
      choices: document.getElementById('choices'),
      overlay: document.getElementById('overlay'),
      drawer: document.getElementById('drawer'),
      drawerTitle: document.getElementById('drawerTitle'),
