    function addLog(speaker, text) {
      state.log = [...state.log, { speaker, text }].slice(-14);
      renderLog();
    }

    function makeInitialLog(pnj) {
      return [
        { speaker: 'system', text: pnj.isFabrist ? 'Score en vrille : FABRISTE débarque.' : `${pnj.name} entre dans ton champ de vision.` },
        { speaker: pnj.name, text: pnj.isFabrist ? 'FABRISTE te mate avec un enthousiasme très inquiétant.' : 'Elle te regarde. À toi d’ouvrir.' },
      ];
    }

    function setupEncounter(nextScore = state.score) {
      const next = createCharacter(nextScore <= -3);
      state.current = next;
      state.stage = 'opening';
      state.greens = 0;
      state.reds = 0;
      state.discreetTurns = 0;
      state.choices = [...INTRO_OPTIONS];
      state.log = makeInitialLog(next);
      state.status = 'active';
      state.playerEmotion = 'desir';
      state.npcEmotion = next.isFabrist ? 'joie' : 'tristesse';
      state.overlay = false;
      render();
    }

    function rememberBestiary(pnj) {
      if (pnj.isFabrist) return;
      const existing = state.bestiary.find((e) => e.signature === pnj.signature);
      if (existing) existing.wins += 1;
      else state.bestiary.unshift({ signature: pnj.signature, likedTags: pnj.likedTags, dislikedTags: pnj.dislikedTags, wins: 1 });
    }

    function recordHistory(pnj, outcome, delta, finalScore) {
      state.history.unshift({ id: `${pnj.id}-${Date.now()}`, name: pnj.name, signature: pnj.signature, outcome, delta, finalScore });
      state.history = state.history.slice(0, 18);
    }

    function playTurtleScreams() {
      try {
        const AudioCtx = window.AudioContext || window.webkitAudioContext;
        if (!AudioCtx) return;
        const ctx = new AudioCtx();
        const now = ctx.currentTime;
        for (let i = 0; i < 5; i++) {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = i % 2 === 0 ? 'square' : 'sawtooth';
          osc.frequency.setValueAtTime(420 + i * 60, now + i * 0.18);
          osc.frequency.exponentialRampToValueAtTime(900 + i * 40, now + i * 0.26);
          gain.gain.setValueAtTime(0.0001, now + i * 0.18);
          gain.gain.exponentialRampToValueAtTime(0.045, now + i * 0.2);
          gain.gain.exponentialRampToValueAtTime(0.0001, now + i * 0.32);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now + i * 0.18);
          osc.stop(now + i * 0.33);
        }
      } catch {}
    }

    function loseEncounter(reason, harsh = false, npcMood = null) {
      const nextScore = state.score - 1;
      state.score = nextScore;
      state.status = 'lost';
      state.playerEmotion = 'tristesse';
      state.npcEmotion = npcMood || (harsh ? 'colere' : 'degout');
      addLog(state.current.name, reason || pickRejectText(harsh));
      addLog('system', 'Raté. -1 point.');
      recordHistory(state.current, 'échec', -1, nextScore);
      render();
    }

    function winEncounter() {
      const nextScore = state.score + 2;
      state.score = nextScore;
      state.status = 'won';
      state.playerEmotion = 'joie';
      state.npcEmotion = state.current.isFabrist ? 'joie' : 'desir';
      addLog(state.current.name, state.current.isFabrist ? 'FABRISTE valide tout, dans un mélange de désir et de chaos.' : 'Ok. Cette fois, elle vient avec toi.');
      addLog('system', '+2 points, bien joué.');
      recordHistory(state.current, 'conclusion', 2, nextScore);
      rememberBestiary(state.current);
      state.overlay = true;
      render();
      playTurtleScreams();
      setTimeout(() => {
        state.overlay = false;
        render();
      }, 2600);
    }

    function evaluateFlirt(choice) {
      if (state.current.isFabrist) {
        const nextGreens = state.greens + 1;
        state.greens = nextGreens;
        state.playerEmotion = nextGreens >= 3 ? 'joie' : 'desir';
        state.npcEmotion = nextGreens >= 3 ? 'desir' : 'joie';
        addLog(state.current.name, getReply(state.current, nextGreens >= 3 ? 'unlock' : 'positive'));
        if (nextGreens >= 3) {
          state.stage = 'conclusion';
          state.choices = [...FABRISTE_FINALS];
        } else if (state.stage === 'discreet') {
          const nextTurns = state.discreetTurns + 1;
          state.discreetTurns = nextTurns;
          state.choices = nextTurns >= 2 ? sampleUnique(REAL_POOL, 3) : sampleUnique(DISCREET_POOL, 3);
          if (nextTurns >= 2) state.stage = 'real';
        } else {
          state.choices = state.stage === 'real' ? sampleUnique(REAL_POOL, 3) : sampleUnique(DISCREET_POOL, 3);
        }
        render();
        return;
      }

      if (state.current.redUltimate && choice.id === state.current.redUltimate.id) {
        loseEncounter(pickRejectText(true), true);
        return;
      }

      let deltaGreen = 0;
      let deltaRed = 0;
      let tone = 'neutral';
      let unlockConclusion = false;

      if (state.current.greenUltimate && choice.id === state.current.greenUltimate.id) {
        deltaGreen = 2;
        tone = 'unlock';
        unlockConclusion = true;
      } else if (state.current.greenFlagIds.has(choice.id) || state.current.likedTags.includes(choice.tag || '')) {
        deltaGreen = 1;
        tone = 'positive';
      } else if (state.current.redFlagIds.has(choice.id) || state.current.dislikedTags.includes(choice.tag || '')) {
        deltaRed = 1;
        tone = 'negative';
      }

      state.greens += deltaGreen;
      state.reds += deltaRed;
      state.playerEmotion = playerEmotionFromTone(unlockConclusion ? 'unlock' : tone);
      state.npcEmotion = npcEmotionFromTone(unlockConclusion ? 'unlock' : tone, state.current.isFabrist);
      addLog(state.current.name, getReply(state.current, unlockConclusion ? 'unlock' : tone));

      if (state.reds - state.greens >= 6) {
        loseEncounter(pickRejectText(deltaRed > 0), deltaRed > 0);
        return;
      }

      if (unlockConclusion || state.greens >= 3) {
        state.stage = 'conclusion';
        state.choices = [...CONCLUSION_OPTIONS];
        addLog(state.current.name, getReply(state.current, 'final'));
        render();
        return;
      }

      if (state.stage === 'discreet') {
        const nextTurns = state.discreetTurns + 1;
        state.discreetTurns = nextTurns;
        if (nextTurns >= 2) {
          state.stage = 'real';
          state.choices = sampleUnique(REAL_POOL, 3);
        } else {
          state.choices = sampleUnique(DISCREET_POOL, 3);
        }
        render();
        return;
      }

      state.choices = sampleUnique(REAL_POOL, 3);
      render();
    }

    function choose(choice) {
      if (state.status !== 'active') return;
      addLog('Guy-Mauve', choice.text);

      if (state.stage === 'opening') {
        const goodOpening = state.current.isFabrist || choice.id === `o${state.current.allowedOpener}`;
        if (!goodOpening) {
          loseEncounter(pickRejectText(true), true, 'colere');
          return;
        }
        state.playerEmotion = 'desir';
        state.npcEmotion = state.current.isFabrist ? 'joie' : 'desir';
        addLog(state.current.name, getReply(state.current, 'intro'));
        state.stage = 'discreet';
        state.choices = sampleUnique(DISCREET_POOL, 3);
        render();
        return;
      }

      if (state.stage === 'conclusion') {
        if (state.current.isFabrist) {
          winEncounter();
          return;
        }
        if (choice.id === `c${state.current.preferredConclusion}`) {
          winEncounter();
          return;
        }
        const diff = state.reds - state.greens;
        if (diff >= 2) {
          loseEncounter(pickRejectText(true), true, 'degout');
          return;
        }
        state.reds += 1;
        state.playerEmotion = 'tristesse';
        state.npcEmotion = 'degout';
        addLog(state.current.name, 'Pas encore. Reviens avec quelque chose de mieux si tu veux me faire bouger.');
        if (state.reds - state.greens >= 6) {
          loseEncounter(pickRejectText(true), true);
          return;
        }
        state.stage = 'real';
        state.choices = sampleUnique(REAL_POOL, 3);
        render();
        return;
      }

      evaluateFlirt(choice);
    }

    function phaseLabel() {
      return {
        opening: '1 · première approche',
