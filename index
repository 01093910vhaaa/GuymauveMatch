            <path d="M100 79 L117 77" stroke="rgba(0,0,0,.52)" stroke-width="3" stroke-linecap="round"/>
            <path d="M143 77 L160 79" stroke="rgba(0,0,0,.52)" stroke-width="3" stroke-linecap="round"/>
            <path d="M128 93 Q133 104 129 112" stroke="rgba(0,0,0,.16)" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="${mouth.replace(/M(\d+)/, (_, n) => 'M' + (parseInt(n)+75)).replace(/Q(\d+)/, (_, n) => 'Q' + (parseInt(n)+80)).replace(/(\d+) 84/, '130 120').replace(/(\d+) 75$/, '141 112')}" fill="none" stroke="${isNpcWoman ? 'rgba(126,46,86,.82)' : 'rgba(79,34,41,.78)'}" stroke-width="2.8" stroke-linecap="round"/>
            ${isNpcWoman ? `<ellipse cx="94" cy="108" rx="6.5" ry="4" fill="rgba(244,114,182,.24)"/><ellipse cx="166" cy="108" rx="6.5" ry="4" fill="rgba(244,114,182,.24)"/>` : ''}
            ${isFabrist ? `<path d="M111 105 q6 12 0 22" stroke="#4e2f1b" stroke-width="8" fill="none" stroke-linecap="round"/><path d="M149 105 q-6 12 0 22" stroke="#4e2f1b" stroke-width="8" fill="none" stroke-linecap="round"/><path d="M112 118 q18 12 36 0" stroke="#4e2f1b" stroke-width="10" fill="none" stroke-linecap="round"/>` : ''}
          </g>
        </svg>`;
    }

    function renderChoices() {
      els.choices.innerHTML = '';
      state.choices.forEach((choice) => {
        const btn = document.createElement('button');
        btn.className = 'choice';
        btn.textContent = choice.text;
        btn.disabled = state.status !== 'active';
        btn.addEventListener('click', () => choose(choice));
        els.choices.appendChild(btn);
      });
    }

    function renderDrawer() {
      const open = !!state.drawer;
      els.drawer.classList.toggle('show', open);
      if (!open) return;
      els.drawerTitle.textContent = state.drawer === 'bestiary' ? 'Carnet' : 'Archives';
      els.drawerBody.innerHTML = '';
      if (state.drawer === 'bestiary') {
        if (!state.bestiary.length) {
          els.drawerBody.innerHTML = '<div class="entry"><div class="entry-sub">Le carnet se remplit seulement après une vraie conclusion.</div></div>';
          return;
        }
        state.bestiary.forEach((entry) => {
          const el = document.createElement('div');
          el.className = 'entry';
          el.innerHTML = `<div class="entry-title">${entry.signature}</div><div class="entry-sub"><span class="good">Aime :</span> ${entry.likedTags.join(', ')}</div><div class="entry-sub" style="margin-top:6px"><span class="bad">Supporte pas :</span> ${entry.dislikedTags.join(', ')}</div>`;
          els.drawerBody.appendChild(el);
        });
      } else {
        if (!state.history.length) {
          els.drawerBody.innerHTML = '<div class="entry"><div class="entry-sub">Aucune rencontre gardée en mémoire.</div></div>';
          return;
        }
        state.history.forEach((item) => {
          const el = document.createElement('div');
          el.className = 'entry';
          el.innerHTML = `<div style="display:flex;justify-content:space-between;gap:12px"><div class="entry-title">${item.name}</div><div class="${item.delta > 0 ? 'good' : 'bad'}">${item.delta > 0 ? '+' : ''}${item.delta}</div></div><div class="entry-sub">${item.signature}</div>`;
          els.drawerBody.appendChild(el);
        });
      }
    }

    function render() {
      els.scoreValue.textContent = String(state.score);
      els.npcName.textContent = state.current?.name || '—';
      els.playerEmotion.textContent = EMOJI[state.playerEmotion] || '❤️';
      els.npcEmotion.textContent = EMOJI[state.npcEmotion] || '😞';
      els.phaseLabel.textContent = phaseLabel();
      els.restartBtn.textContent = state.status === 'active' ? 'Recommencer' : state.score <= -3 ? 'FABRISTE' : 'Nouvelle rencontre';
      els.overlay.classList.toggle('show', state.overlay);
      renderLog();
      renderChoices();
      renderDrawer();
      drawPortrait(els.playerPortrait, {
        name: 'Guy-Mauve', id: 'guy', isFabrist: false, face: { key: 'ovale' }, body: { key: 'compacte' }, skin: '#e2b28a', hair: { key: 'brun-nuit', color: '#4a2b20' }, eyes: { color: '#8fa6c8' }
      }, true, state.playerEmotion);
      drawPortrait(els.npcPortrait, state.current, false, state.npcEmotion);
    }

    els.restartBtn.addEventListener('click', () => setupEncounter(state.score));
    els.historyBtn.addEventListener('click', () => { state.drawer = 'history'; renderDrawer(); });
    els.bestiaryBtn.addEventListener('click', () => { state.drawer = 'bestiary'; renderDrawer(); });
    els.closeDrawerBtn.addEventListener('click', () => { state.drawer = null; renderDrawer(); });
    els.drawer.addEventListener('click', (e) => { if (e.target === els.drawer) { state.drawer = null; renderDrawer(); } });

    setupEncounter(0);
  </script>
</body>
</html>
