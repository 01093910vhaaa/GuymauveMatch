<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Guy-Mauve tente sa chance</title>
  <style>
    :root {
      --bg1: #5a3856;
      --bg2: #1c1220;
      --bg3: #0c0810;
      --panel: rgba(255,255,255,.06);
      --panel-2: rgba(255,255,255,.08);
      --border: rgba(255,255,255,.12);
      --text: #f7f3fb;
      --muted: rgba(247,243,251,.65);
      --accent: #d660b8;
      --accent-2: #f0b0df;
      --good: #74d7a7;
      --bad: #ff8a9b;
      --gold: #f6d27a;
      --shadow: 0 20px 50px rgba(0,0,0,.28);
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; min-height: 100%; }
    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background: radial-gradient(circle at top, var(--bg1), var(--bg2) 58%, var(--bg3));
    }

    .app {
      max-width: 980px;
      margin: 0 auto;
      min-height: 100vh;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .card {
      border: 1px solid var(--border);
      background: var(--panel);
      backdrop-filter: blur(8px);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      align-items: center;
    }

    .eyebrow {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .34em;
      color: rgba(255,255,255,.45);
      margin-bottom: 4px;
    }

    h1 {
      margin: 0;
      font-size: clamp(28px, 5vw, 44px);
      line-height: 1;
    }

    .top-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .badge {
      min-width: 90px;
      padding: 8px 10px;
      border-radius: 14px;
      background: rgba(246,210,122,.18);
      color: #fff4c9;
      text-align: center;
      border: 1px solid rgba(246,210,122,.14);
    }

    .badge small {
      display: block;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .2em;
      color: rgba(255,255,255,.5);
      margin-bottom: 4px;
    }

    button {
      appearance: none;
      border: 1px solid var(--border);
      background: rgba(255,255,255,.08);
      color: var(--text);
      border-radius: 14px;
      padding: 10px 12px;
      cursor: pointer;
      transition: .16s ease;
      font: inherit;
    }

    button:hover { background: rgba(255,255,255,.14); transform: translateY(-1px); }
    button:disabled { opacity: .45; cursor: default; transform: none; }

    .portrait-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .portrait-card { padding: 8px; }

    .portrait-label {
      text-align: center;
      font-size: 11px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.84);
      margin-bottom: 4px;
    }

    .portrait {
      position: relative;
      height: min(27vh, 280px);
      min-height: 170px;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.08);
      background:
        radial-gradient(circle at 50% 14%, rgba(255,255,255,.12), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,.06), transparent 28%, rgba(0,0,0,.28));
    }

    .portrait svg { position: absolute; inset: 0; width: 100%; height: 100%; }
    .emotion {
      position: absolute;
      right: 8px;
      bottom: 6px;
      font-size: 18px;
    }

    .main {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 12px;
      flex: 1;
    }

    .phase {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .phase small {
      display: block;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .3em;
      color: rgba(255,255,255,.45);
      margin-bottom: 4px;
    }

    .phase strong {
      font-size: 18px;
    }

    .log {
      min-height: 170px;
      max-height: 220px;
      overflow-y: auto;
      padding: 10px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(0,0,0,.22);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .bubble {
      max-width: 94%;
      border-radius: 15px;
      padding: 10px 12px;
      line-height: 1.4;
      font-size: 14px;
    }

    .bubble .speaker {
      display: block;
      margin-bottom: 4px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .22em;
      color: rgba(255,255,255,.48);
    }

    .bubble.player { margin-left: auto; background: rgba(214,96,184,.18); }
    .bubble.npc { margin-right: auto; background: rgba(255,255,255,.10); }
    .bubble.system { margin: 0 auto; background: rgba(255,255,255,.08); color: rgba(255,255,255,.8); max-width: 96%; }

    .choices {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .choice { text-align: left; min-height: 74px; }

    .overlay,
    .drawer {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 50;
    }

    .overlay.show,
    .drawer.show { display: flex; }

    .overlay {
      pointer-events: none;
      background: rgba(0,0,0,.72);
      backdrop-filter: blur(6px);
    }

    .blur-scene {
      position: relative;
      width: min(80vw, 520px);
      height: min(40vh, 320px);
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.1);
      background: #20151f;
    }

    .blur-shape {
      position: absolute;
      border-radius: 2rem;
      filter: blur(5px);
    }

    .drawer {
      background: rgba(0,0,0,.62);
      backdrop-filter: blur(8px);
      padding: 16px;
    }

    .drawer-panel {
      width: min(860px, 100%);
      max-height: 82vh;
      overflow: hidden;
      border-radius: 22px;
      background: rgba(23,17,26,.96);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
    }

    .drawer-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
    }

    .drawer-body {
      padding: 16px;
      overflow-y: auto;
      display: grid;
      gap: 10px;
    }

    .entry {
      padding: 14px;
      border-radius: 16px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
    }

    .entry-title { font-weight: 600; margin-bottom: 6px; }
    .entry-sub { color: var(--muted); font-size: 14px; }
    .good { color: var(--good); }
    .bad { color: var(--bad); }

    @media (max-width: 760px) {
      .topbar { flex-direction: column; align-items: stretch; }
      .top-actions { justify-content: flex-start; }
      .portrait-grid { grid-template-columns: 1fr 1fr; }
      .choices { grid-template-columns: 1fr; }
      .portrait { min-height: 150px; height: 22vh; }
      .log { max-height: 180px; }
    }
  </style>
</head>
<body>
  <div class="app">
